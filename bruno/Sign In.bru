meta {
  name: Sign In
  type: http
  seq: 3
}

post {
  url: {{host}}/api/auth/signin
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {"email": "{{test_email}}", "password": "{{test_password}}"}
}

script:post-response {
  let data = res.getBody();
  if (data.user && data.user.id) {
    bru.setEnvVar("test_user_id", data.user.id);
  }
}
