meta {
  name: Player Search
  type: http
  seq: 5
}

post {
  url: {{host}}/api/player/search
  body: json
  auth: none
}

body:json {
  {
    "name": "{{test_player_name}}"
  }
}

script:post-response {
  let data = res.getBody();
  if (data.player && data.player.memberNumber) {
    bru.setEnvVar("test_member_id", data.player.memberNumber);
  }
  if (data.teams && data.teams.length > 0) {
    bru.setEnvVar("test_team_id", data.teams[0].apaId);
  }
}
