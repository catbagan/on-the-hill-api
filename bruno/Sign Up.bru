meta {
  name: Sign Up
  type: http
  seq: 2
}

post {
  url: {{host}}/api/auth/signup
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{test_email}}",
    "password": "{{test_password}}",
    "givenName": "Test",
    "familyName": "User"
  }
}

script:post-response {
  let data = res.getBody();
  if (data.user && data.user.id) {
    bru.setEnvVar("test_user_id", data.user.id);
  }
}
