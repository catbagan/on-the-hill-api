{
  "name": "on-the-hill-api",
  "version": "0.0.1",
  "description": "On The Hill API - Pool player statistics and reports",
  "scripts": {
    "build": "echo 'no-op — runtime uses tsx, no tsc build needed'",
    "start": "tsx src/node-server.ts",
    "dev": "tsx watch src/node-server.ts",
    "typecheck": "tsc --noEmit",
    "biome": "biome check --write .",
    "scrape": "tsx src/scraper.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:record": "tsx tests/scripts/record-fixtures.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.2",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "dotenv": "^17.2.1",
    "hono": "^4.8.10",
    "tsx": "^4.20.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.3",
    "@types/node": "^20.19.9",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "20.16.0"
  }
}
